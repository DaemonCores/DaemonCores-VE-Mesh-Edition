#!/bin/bash
#
# fanctl — generic self-calibrating fan controller over local IPMI
#
# Usage: fanctl [--daemon|--check|--calibrate|--restore|--once]
#   --daemon     Run the control loop (default when no argument is given).
#   --check      Print discovered sensors, fans, vendor and current metrics.
#   --calibrate  Force a calibration pass, persist the result, and exit.
#   --restore    Hand fan regulation back to the BMC (automatic) and exit.
#   --once       Print one metrics line and exit.
#
# How it works:
#   Temperature sensors and their own Upper-Critical thresholds are discovered
#   at runtime, so nothing is hard-coded. Sensors whose Upper-Critical is high
#   enough (CONTROL_UCR_MIN) are the controlling (CPU-class) sensors; the daemon
#   holds the hottest of them near TARGET_TEMP.
#
#   Calibration measures the real thermal response of THIS machine: it converges
#   the fan speed to the quiet operating point that holds the target, and records
#   the fan/temperature slope. The result (CAL_PCT, CAL_SLOPE, CAL_INLET) is
#   persisted so it survives restarts. In normal operation the daemon applies a
#   proportional correction around the calibrated point, and recalibrates by
#   itself when the error stays large (too hot, or fans running harder than the
#   temperature warrants) or when the inlet air temperature drifts.
#
#   Safety is temperature-based, never fan-count-based: a single failed fan among
#   many has no special handling; only an over-temperature (near Upper-Critical)
#   forces maximum cooling. Writing the fan speed uses an auto-detected vendor
#   profile (ipmitool mc info); an unknown vendor stays in read-only monitor mode.
#
# Note on shell options: the daemon deliberately does not use "set -e"; a
# transient ipmitool failure must not kill the control loop.

set -uo pipefail

readonly CONF=/etc/fanctl/fanctl.conf
readonly STATE_DIR=/var/lib/fanctl
readonly STATE_FILE="${STATE_DIR}/calibration.conf"

# --- Defaults (overridden by CONF) ------------------------------------------
IPMITOOL=ipmitool         # ipmitool binary; local IPMI via /dev/ipmi0.
POLL_INTERVAL=20          # Seconds between control cycles.
MIN_PCT=10                # Fan speed floor, percent (keeps baseline airflow).
MAX_PCT=100               # Fan speed ceiling, percent.
TARGET_TEMP=60            # Target for the hottest controlling sensor, deg C.
HARD_MARGIN=10            # Emergency: force max at Upper-Critical minus this.
CONTROL_UCR_MIN=80        # A sensor with Upper-Critical >= this is CPU-class.
HWMON_CPU_CRIT=95         # Fallback critical temp for hwmon sensors lacking one.
AMBIENT_MATCH='Inlet|Ambient'  # Regex for the inlet-air sensor.
HYST_PCT=3                # Minimum percent change before issuing a command.
TRIM_MAX=4                # Max fan change per cycle while holding, percent.
MAX_FAIL=3                # Consecutive IPMI read errors before failsafe.
REQUIRE_KNOWN_VENDOR=0    # 1 = exit on unknown vendor; 0 = monitor mode.

# Calibration and drift tuning.
DEADBAND=3                # Convergence tolerance during calibration, deg C.
DRIFT=8                   # Sustained |error| that triggers recalibration, deg C.
DRIFT_CYCLES=5            # Cycles the drift must persist before recalibrating.
INLET_DRIFT=5            # Inlet change vs calibration that triggers recal, deg C.
STABILIZE_SECS=40         # Settle time after a fan change while calibrating.
MAX_CAL_STEPS=10          # Maximum convergence steps per calibration.
CAL_STEP_MIN=2            # Minimum per-step fan change while calibrating, pct.
CAL_STEP_MAX=12           # Maximum per-step fan change while calibrating, pct.
DEFAULT_GAIN=3            # Fallback proportional gain, percent per deg C.

# shellcheck source=/dev/null
[[ -r "$CONF" ]] && . "$CONF"

# --- Runtime state ----------------------------------------------------------
BACKEND=none              # Fan-control backend: ipmi | hwmon | none.
# IPMI backend: detected vendor and its manual/auto raw commands.
IPMI_VENDOR=unknown
RAW_MANUAL=''
RAW_AUTO=''
# hwmon backend: parallel arrays of controllable PWM channels.
HWMON_PWM=()              # Paths to writable pwmN files.
HWMON_EN=()               # Matching pwmN_enable paths.
HWMON_EN_ORIG=()          # Their original enable values (restored on stop).
MODE=auto                 # Current control mode: auto | manual.
LAST_PCT=-1               # Last applied speed, percent (-1 = unknown).
FAIL_COUNT=0              # Consecutive IPMI read failures.
DRIFT_COUNT=0             # Consecutive cycles with |error| > DRIFT.
EMERG_COUNT=0             # Consecutive over-temperature cycles.

# Persisted calibration (loaded from STATE_FILE).
CAL_PCT=0                 # Calibrated operating fan speed, percent.
CAL_SLOPE=0               # Measured response, deg C per percent (negative).
CAL_INLET=0               # Inlet temperature at calibration time, deg C.

# Metrics from the last read (set by eval of read_metrics).
T=0                       # Hottest controlling sensor, deg C.
CRITMIN=0                 # Lowest Upper-Critical among controlling sensors.
INLET=0                   # Inlet-air temperature, deg C.
NCTRL=0                   # Number of controlling sensors seen.

log() {
  printf '%s fanctl: %s\n' "$(date '+%Y-%m-%dT%H:%M:%S%z')" "$*"
}

#######################################
# Find writable hwmon PWM channels (standard PC fan control, no IPMI).
# Globals:
#   HWMON_PWM, HWMON_EN, HWMON_EN_ORIG (write)
# Returns:
#   0 if at least one controllable channel was found, 1 otherwise.
#######################################
detect_hwmon() {
  local pwm en
  for pwm in /sys/class/hwmon/hwmon*/pwm[0-9]*; do
    [[ "$pwm" =~ /pwm[0-9]+$ ]] || continue   # skip pwmN_enable, pwmN_auto_*
    en="${pwm}_enable"
    [[ -w "$pwm" && -e "$en" ]] || continue
    HWMON_PWM+=("$pwm")
    HWMON_EN+=("$en")
    HWMON_EN_ORIG+=("$(cat "$en" 2>/dev/null || echo 2)")
  done
  [[ ${#HWMON_PWM[@]} -gt 0 ]]
}

#######################################
# Map an IPMI Manufacturer ID to a fan-control profile. Reading temperatures and
# fan tachometers over IPMI is standard across vendors; only the WRITE commands
# are OEM-specific, so this table is where brand support is added. Add a case to
# support a new vendor. Dell is verified on real hardware; other entries come
# from vendor documentation. The per-vendor speed encoding lives in fan_set.
# Globals:
#   IPMI_VENDOR, RAW_MANUAL, RAW_AUTO (write)
# Arguments:
#   $1 - Manufacturer ID (IANA number)
#######################################
ipmi_profile() {
  case "$1" in
    674)    # Dell (iDRAC 7/8/9) — verified.
      IPMI_VENDOR=dell
      RAW_MANUAL='0x30 0x30 0x01 0x00'
      RAW_AUTO='0x30 0x30 0x01 0x01'
      ;;
    10876)  # Supermicro (X9/X10/X11) — from documentation; zone-based speed.
      IPMI_VENDOR=supermicro
      RAW_MANUAL='0x30 0x45 0x01 0x01'
      RAW_AUTO='0x30 0x45 0x01 0x00'
      ;;
    *)
      IPMI_VENDOR=unknown
      ;;
  esac
}

#######################################
# Select the fan-control backend: a profiled IPMI BMC (any brand), else hwmon.
# An IPMI BMC whose vendor is not profiled still allows read-only monitoring.
# Globals:
#   IPMITOOL (read); BACKEND, IPMI_VENDOR, RAW_*, HWMON_* (write)
#######################################
detect_backend() {
  local mc mfg
  mc=$("$IPMITOOL" mc info 2>/dev/null) || true
  mfg=$(awk -F: '/Manufacturer ID/ {gsub(/[^0-9]/, "", $2); print $2; exit}' \
    <<<"$mc")
  ipmi_profile "$mfg"
  if [[ -n "$RAW_MANUAL" ]]; then
    BACKEND=ipmi
    log "backend: ipmi/${IPMI_VENDOR} (Manufacturer ID=${mfg})"
    return
  fi
  if detect_hwmon; then
    BACKEND=hwmon
    log "backend: hwmon (${#HWMON_PWM[@]} controllable PWM channel(s))"
    return
  fi
  BACKEND=none
  if [[ -n "$mfg" ]]; then
    log "backend: none (IPMI vendor ${mfg} not profiled; monitoring via IPMI)"
  else
    log "backend: none (no controllable fan interface; monitor only)"
  fi
}

can_control() {
  [[ "$BACKEND" != none ]]
}

fan_auto() {
  case "$BACKEND" in
    ipmi) "$IPMITOOL" raw $RAW_AUTO >/dev/null 2>&1 ;;
    hwmon)
      local i
      for i in "${!HWMON_EN[@]}"; do
        echo "${HWMON_EN_ORIG[$i]}" > "${HWMON_EN[$i]}" 2>/dev/null
      done ;;
    *) return 0 ;;
  esac
}

fan_manual() {
  case "$BACKEND" in
    ipmi) "$IPMITOOL" raw $RAW_MANUAL >/dev/null 2>&1 ;;
    hwmon)
      local en
      for en in "${HWMON_EN[@]}"; do echo 1 > "$en" 2>/dev/null; done ;;
    *) return 0 ;;
  esac
}

#######################################
# Set all fans to a given speed and remember it. The IPMI speed encoding is
# per-vendor (Dell: one command, all fans; Supermicro: one per fan zone).
# Globals:
#   BACKEND, IPMI_VENDOR, IPMITOOL, HWMON_PWM (read), LAST_PCT (write)
# Arguments:
#   $1 - speed as a decimal percent
# Returns:
#   0 on success, 1 on failure.
#######################################
fan_set() {
  case "$BACKEND" in
    ipmi)
      local hex; hex=$(printf '0x%02x' "$1")
      case "$IPMI_VENDOR" in
        dell)
          "$IPMITOOL" raw 0x30 0x30 0x02 0xff "$hex" >/dev/null 2>&1 || return 1
          ;;
        supermicro)
          local z
          for z in 0x00 0x01; do
            "$IPMITOOL" raw 0x30 0x70 0x66 0x01 "$z" "$hex" >/dev/null 2>&1 \
              || return 1
          done
          ;;
        *) return 1 ;;
      esac
      ;;
    hwmon)
      local pwmval p; pwmval=$(( $1 * 255 / 100 ))
      (( pwmval > 255 )) && pwmval=255
      for p in "${HWMON_PWM[@]}"; do
        echo "$pwmval" > "$p" 2>/dev/null || return 1
      done
      ;;
    *) return 1 ;;
  esac
  LAST_PCT="$1"
  return 0
}

to_auto() {
  [[ "$MODE" == auto ]] && return 0
  if fan_auto; then
    MODE=auto
    LAST_PCT=-1
  fi
}

to_manual() {
  [[ "$MODE" == manual ]] && return 0
  fan_manual && MODE=manual
}

#######################################
# Apply a fan speed with hysteresis (clamped to [MIN_PCT, MAX_PCT]).
# Arguments:
#   $1 - desired percent
#######################################
apply_pct() {
  local pct="$1" delta
  (( pct < MIN_PCT )) && pct="$MIN_PCT"
  (( pct > MAX_PCT )) && pct="$MAX_PCT"
  to_manual
  delta=$(( pct > LAST_PCT ? pct - LAST_PCT : LAST_PCT - pct ))
  if (( LAST_PCT < 0 || delta >= HYST_PCT )); then
    if fan_set "$pct"; then
      log "fans -> ${pct}% (T=${T}C target=$(effective_target)C)"
    else
      log "failed to set fan speed -> automatic fan control"
      to_auto
    fi
  fi
}

#######################################
# Read metrics via IPMI in a single ipmitool pass.
# Globals:
#   IPMITOOL, CONTROL_UCR_MIN, AMBIENT_MATCH (read)
# Outputs:
#   "T=<hottest> CRITMIN=<min ucr> INLET=<inlet> NCTRL=<n>" to stdout.
# Returns:
#   0 on success, 1 if IPMI returned nothing.
#######################################
read_metrics_ipmi() {
  local out
  out=$("$IPMITOOL" sensor 2>/dev/null) || return 1
  [[ -n "$out" ]] || return 1
  awk -F'|' -v umin="$CONTROL_UCR_MIN" -v amb="$AMBIENT_MATCH" '
    function trim(s) { gsub(/^[ \t]+|[ \t]+$/, "", s); return s }
    { name = trim($1); reading = trim($2); unit = trim($3); ucr = trim($9) }
    unit ~ /degrees C/ && reading ~ /^[0-9]+(\.[0-9]+)?$/ {
      r = reading + 0
      if (name ~ amb) inlet = r
      has_ucr = (ucr ~ /^[0-9]+(\.[0-9]+)?$/)
      if (has_ucr && (ucr + 0) >= umin) {
        nctrl++
        if (r > hottest) hottest = r
        if (critmin == 0 || (ucr + 0) < critmin) critmin = ucr + 0
      }
    }
    END {
      printf "T=%d CRITMIN=%d INLET=%d NCTRL=%d\n", \
        int(hottest + 0.5), int(critmin + 0.5), int(inlet + 0.5), nctrl + 0
    }' <<<"$out"
}

#######################################
# Read metrics from Linux hwmon sensors (coretemp, k10temp, ...).
# A sensor counts as controlling when its critical threshold is CPU-class, or
# when its label looks like a CPU domain (fallback critical = HWMON_CPU_CRIT).
# Globals:
#   CONTROL_UCR_MIN, HWMON_CPU_CRIT, AMBIENT_MATCH (read)
# Outputs:
#   "T=<hottest> CRITMIN=<min crit> INLET=<inlet> NCTRL=<n>" to stdout.
# Returns:
#   0 if any temperature was read, 1 otherwise.
#######################################
read_metrics_hwmon() {
  local ti base val label crit
  local hottest=0 critmin=0 inlet=0 nctrl=0 any=0 tdeg cdeg
  for ti in /sys/class/hwmon/hwmon*/temp[0-9]*_input; do
    [[ -r "$ti" ]] || continue
    val=$(cat "$ti" 2>/dev/null); [[ "$val" =~ ^[0-9]+$ ]] || continue
    any=1
    tdeg=$(( val / 1000 ))
    base="${ti%_input}"
    label=$(cat "${base}_label" 2>/dev/null || echo "")
    [[ "$label" =~ $AMBIENT_MATCH ]] && inlet=$tdeg
    crit=$(cat "${base}_crit" 2>/dev/null || echo "")
    if [[ "$crit" =~ ^[0-9]+$ ]]; then cdeg=$(( crit / 1000 )); else cdeg=0; fi
    if (( cdeg >= CONTROL_UCR_MIN )); then
      :
    elif [[ "$label" =~ (Package|Tctl|Tdie|Core|CPU) ]]; then
      cdeg=$HWMON_CPU_CRIT
    else
      continue
    fi
    (( nctrl++ ))
    (( tdeg > hottest )) && hottest=$tdeg
    (( critmin == 0 || cdeg < critmin )) && critmin=$cdeg
  done
  (( any == 0 )) && return 1
  printf "T=%d CRITMIN=%d INLET=%d NCTRL=%d\n" \
    "$hottest" "$critmin" "$inlet" "$nctrl"
}

#######################################
# Read metrics through whichever source fits the active backend.
# Falls back to trying both in monitor mode so temperatures can still be logged.
# Globals:
#   BACKEND, IPMITOOL (read)
#######################################
read_metrics() {
  case "$BACKEND" in
    ipmi) read_metrics_ipmi ;;
    hwmon) read_metrics_hwmon ;;
    *) read_metrics_ipmi || read_metrics_hwmon ;;
  esac
}

#######################################
# Compute the effective target, kept safely below Upper-Critical.
# Globals:
#   TARGET_TEMP, CRITMIN, HARD_MARGIN (read)
# Outputs:
#   The effective target temperature to stdout.
#######################################
effective_target() {
  local ceiling=$(( CRITMIN - HARD_MARGIN - 5 ))
  if (( CRITMIN > 0 && TARGET_TEMP > ceiling )); then
    echo "$ceiling"
  else
    echo "$TARGET_TEMP"
  fi
}

#######################################
# Proportional gain (percent per deg C) from the calibrated slope.
# Globals:
#   CAL_SLOPE, DEFAULT_GAIN (read)
# Outputs:
#   The gain to stdout.
#######################################
current_gain() {
  # CAL_SLOPE is deg C per percent (negative); gain is its inverse magnitude.
  awk -v s="$CAL_SLOPE" -v d="$DEFAULT_GAIN" 'BEGIN {
    a = (s < 0) ? -s : s
    if (a < 0.05) { print d; exit }
    g = 1.0 / a
    if (g < 1) g = 1
    if (g > 10) g = 10
    printf "%d", g + 0.5
  }'
}

load_calibration() {
  if [[ -r "$STATE_FILE" ]]; then
    # shellcheck source=/dev/null
    . "$STATE_FILE"
    log "loaded calibration: pct=${CAL_PCT}% slope=${CAL_SLOPE}C/% inlet=${CAL_INLET}C"
    return 0
  fi
  return 1
}

save_calibration() {
  mkdir -p "$STATE_DIR"
  cat > "$STATE_FILE" <<EOF
# Written by fanctl --calibrate. Do not edit by hand.
CAL_PCT=${CAL_PCT}
CAL_SLOPE=${CAL_SLOPE}
CAL_INLET=${CAL_INLET}
CAL_TARGET=$(effective_target)
CAL_TS=$(date '+%Y-%m-%dT%H:%M:%S%z')
EOF
}

#######################################
# Measure the quiet operating point for the current conditions and persist it.
# Converges the fan speed so the hottest sensor sits near the target, and
# derives the fan/temperature slope from the last two convergence points.
# Globals:
#   Calibration tuning and CAL_* state.
#######################################
calibrate() {
  can_control || return 0
  read_metrics_into || return 1
  local target; target=$(effective_target)
  log "calibrating toward ${target}C (inlet=${INLET}C, ${NCTRL} sensors)..."
  to_manual

  local pct prev_pct=-1 prev_t=-1 step err
  pct=$(( CAL_PCT > 0 ? CAL_PCT : (MIN_PCT + MAX_PCT) / 2 ))
  local i
  for (( i = 0; i < MAX_CAL_STEPS; i++ )); do
    (( pct < MIN_PCT )) && pct="$MIN_PCT"
    (( pct > MAX_PCT )) && pct="$MAX_PCT"
    fan_set "$pct"
    sleep "$STABILIZE_SECS"
    read_metrics_into || return 1
    err=$(( T - target ))
    log "  step ${i}: ${pct}% -> ${T}C (err=${err})"

    # Derive the slope from the last two distinct operating points.
    if (( prev_pct >= 0 && pct != prev_pct )); then
      CAL_SLOPE=$(awk -v t1="$prev_t" -v t2="$T" -v p1="$prev_pct" -v p2="$pct" \
        'BEGIN { printf "%.3f", (t2 - t1) / (p2 - p1) }')
    fi

    if (( err <= DEADBAND && err >= -DEADBAND )); then break; fi
    if (( pct <= MIN_PCT && err < 0 )); then break; fi   # As quiet as allowed.
    if (( pct >= MAX_PCT && err > 0 )); then break; fi   # As loud as allowed.

    prev_pct="$pct"; prev_t="$T"
    step=$(( err >= 0 ? err : -err ))
    (( step < CAL_STEP_MIN )) && step="$CAL_STEP_MIN"
    (( step > CAL_STEP_MAX )) && step="$CAL_STEP_MAX"
    (( pct += (err > 0 ? step : -step) ))
  done

  CAL_PCT="$pct"
  CAL_INLET="$INLET"
  save_calibration
  DRIFT_COUNT=0
  log "calibrated: pct=${CAL_PCT}% slope=${CAL_SLOPE}C/% (gain=$(current_gain)%/C)"
}

# read_metrics wrapper that assigns the T/CRITMIN/INLET/NCTRL globals.
read_metrics_into() {
  local line
  line=$(read_metrics) || return 1
  # shellcheck disable=SC2086
  eval "$line"
  return 0
}

cleanup() {
  log "stopping -> restoring automatic fan control"
  can_control && fan_auto
}

do_check() {
  detect_backend
  echo "--- Temperature sensors ---"
  if [[ "$BACKEND" == hwmon ]]; then
    local ti b
    for ti in /sys/class/hwmon/hwmon*/temp[0-9]*_input; do
      [[ -r "$ti" ]] || continue
      b="${ti%_input}"
      printf "  %-24s reading=%sC crit=%sC\n" \
        "$(cat "${b}_label" 2>/dev/null || basename "$b")" \
        "$(( $(cat "$ti") / 1000 ))" \
        "$(( $(cat "${b}_crit" 2>/dev/null || echo 0) / 1000 ))"
    done
  else
    "$IPMITOOL" sensor 2>/dev/null | awk -F'|' '
      function trim(s) { gsub(/^[ \t]+|[ \t]+$/, "", s); return s }
      { u = trim($3) }
      u ~ /degrees C/ {
        printf "  %-22s reading=%-8s upper-crit=%s\n", trim($1), trim($2), trim($9)
      }'
  fi
  echo "--- Fans ---"
  if [[ "$BACKEND" == hwmon ]]; then
    local f
    for f in /sys/class/hwmon/hwmon*/fan[0-9]*_input; do
      [[ -r "$f" ]] && printf "  %s: %s RPM\n" \
        "$(basename "$(dirname "$f")")/$(basename "${f%_input}")" "$(cat "$f")"
    done
  else
    "$IPMITOOL" sdr type fan 2>/dev/null | sed 's/^/  /'
  fi
  echo "--- Metrics ---"
  if read_metrics_into; then
    echo "  T=${T}C CRITMIN=${CRITMIN}C INLET=${INLET}C sensors=${NCTRL}" \
      "target=$(effective_target)C"
  else
    echo "  (no readable sensors)"
  fi
  echo "--- Calibration ---"
  if load_calibration; then :; else echo "  (not calibrated yet)"; fi
  echo "--- Active control available? ---"
  if can_control; then echo "  yes (backend=${BACKEND})"; else
    echo "  no -> monitor mode (backend=${BACKEND})"; fi
}

do_restore() {
  detect_backend
  if can_control; then
    fan_auto && log "regulation handed back (automatic)"
  else
    log "nothing to restore (backend=${BACKEND})"
  fi
}

#######################################
# One regulation cycle: proportional control plus drift-driven recalibration.
# Globals:
#   T, CRITMIN, INLET, CAL_PCT, CAL_INLET, DRIFT_COUNT and tuning.
#######################################
regulate() {
  local target err gain step pct base inlet_delta

  # Temperature-based emergency: force max cooling. Repeated emergencies mean
  # the calibration is badly wrong, so escalate to a recalibration.
  if (( T >= CRITMIN - HARD_MARGIN )); then
    apply_pct "$MAX_PCT"
    (( EMERG_COUNT++ ))
    log "over-temperature (${T}C, crit ${CRITMIN}C) -> max cooling"
    if (( EMERG_COUNT >= DRIFT_CYCLES )); then
      log "repeated over-temperature -> recalibrate"
      calibrate
      EMERG_COUNT=0
    fi
    return
  fi
  EMERG_COUNT=0

  target=$(effective_target)
  err=$(( T - target ))

  # Gentle incremental (integral) tracking: nudge the current speed toward the
  # target by a bounded step. Bounding the per-cycle change keeps it stable and
  # free of the oscillation an unbounded proportional term would cause.
  gain=$(current_gain)
  step=$(( err * gain ))
  (( step > TRIM_MAX )) && step="$TRIM_MAX"
  (( step < -TRIM_MAX )) && step=$(( -TRIM_MAX ))
  if (( step == 0 )); then
    (( err > DEADBAND )) && step=1
    (( err < -DEADBAND )) && step=-1
  fi
  base=$(( LAST_PCT >= 0 ? LAST_PCT : CAL_PCT ))
  pct=$(( base + step ))
  apply_pct "$pct"

  # Keep the persisted operating point fresh while sitting on target.
  if (( err <= DEADBAND && err >= -DEADBAND && LAST_PCT != CAL_PCT )); then
    CAL_PCT="$LAST_PCT"
    CAL_INLET="$INLET"
    save_calibration
  fi

  # A large error the gentle tracking cannot absorb, or a shifted inlet, means
  # the operating point moved a lot: run a fast full recalibration.
  inlet_delta=$(( INLET > CAL_INLET ? INLET - CAL_INLET : CAL_INLET - INLET ))
  if (( err > DRIFT || err < -DRIFT )); then
    (( DRIFT_COUNT++ ))
  else
    DRIFT_COUNT=0
  fi
  if (( DRIFT_COUNT >= DRIFT_CYCLES )); then
    log "sustained drift (err=${err}C) -> recalibrate"
    calibrate
  elif (( inlet_delta > INLET_DRIFT )); then
    log "inlet shifted (${CAL_INLET}C -> ${INLET}C) -> recalibrate"
    calibrate
  fi
}

run_daemon() {
  detect_backend
  if ! can_control; then
    log "no controllable fan backend."
    if [[ "$REQUIRE_KNOWN_VENDOR" == 1 ]]; then
      log "REQUIRE_KNOWN_VENDOR=1 -> exiting"
      exit 0
    fi
    log "monitor mode: read-only, fans left to automatic control."
  fi
  trap cleanup EXIT
  trap 'exit 0' INT TERM
  log "starting (poll=${POLL_INTERVAL}s target=${TARGET_TEMP}C" \
    "range=${MIN_PCT}-${MAX_PCT}%)"

  if can_control; then
    to_manual
    load_calibration || calibrate
  fi

  while :; do
    if ! read_metrics_into; then
      FAIL_COUNT=$((FAIL_COUNT + 1))
      log "IPMI read failed (${FAIL_COUNT}/${MAX_FAIL})"
      (( FAIL_COUNT >= MAX_FAIL )) && can_control && to_auto
      sleep "$POLL_INTERVAL"
      continue
    fi
    FAIL_COUNT=0

    if ! can_control; then
      log "monitor: T=${T}C inlet=${INLET}C sensors=${NCTRL}"
      sleep "$POLL_INTERVAL"
      continue
    fi
    if (( NCTRL == 0 )); then
      log "no controlling sensor readable -> automatic fan control (safety)"
      to_auto
      sleep "$POLL_INTERVAL"
      continue
    fi

    regulate
    sleep "$POLL_INTERVAL"
  done
}

main() {
  case "${1:---daemon}" in
    --check) do_check ;;
    --restore) do_restore ;;
    --calibrate)
      detect_backend
      to_manual
      load_calibration || true
      calibrate
      cleanup
      ;;
    --once) detect_backend; read_metrics ;;
    --daemon) run_daemon ;;
    *)
      echo "usage: fanctl [--daemon|--check|--calibrate|--restore|--once]" >&2
      exit 2
      ;;
  esac
}

main "$@"
